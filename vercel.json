{
  "version": 2,
  "public": true,
  "builds": [
    { "src": "build/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/",           "dest": "/index.html" },
    { "src": "/contato",    "dest": "/contato.html" },
    { "src": "/portfolio",  "dest": "/portfolio.html" },
    { "src": "/processos",  "dest": "/processos.html" },
    { "src": "/servicos",   "dest": "/servicos.html" },
    { "src": "/static/(.*)", "dest": "/static/$1" }
  ]
}

