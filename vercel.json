{
  "version": 2,
  "builds": [
    { "src": "build/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/",           "dest": "/build/index.html" },
    { "src": "/contato",    "dest": "/build/contato.html" },
    { "src": "/portfolio",  "dest": "/build/portfolio.html" },
    { "src": "/processos",  "dest": "/build/processos.html" },
    { "src": "/servicos",   "dest": "/build/servicos.html" },
    { "src": "/static/(.*)", "dest": "/build/static/$1" }
  ]
}
